# Copy to .env.local (already gitignored) and fill values from:
# Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Or newer projects use publishable key instead of anon:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Bucket name used for public PDF URLs (must match your Storage bucket name).
# Default in code is "pdfs" if unset.
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=pdfs
